# Public Spaces/demo default. Keeps all live API/model calls disabled.
DEMO_MODE=false

# Optional secret for local/full evaluations. Never commit a real key.
OPENAI_API_KEY=your_openai_api_key_here

# Dashboard defaults.
DEFAULT_CONFIG_PATH=evals/config.yaml
REPORTS_DIR=reports
ALLOW_LIVE_RUNS=true
BENCHMARK_MODE=demo

# Required only for live WikiRace API runs.
WIKIRACE_API_BASE_URL=
WIKIRACE_MOCK=0
